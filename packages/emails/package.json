{
  "name": "@rallly/emails",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "dev": "email dev --dir ./src/templates",
    "type-check": "tsc --pretty --noEmit",
    "i18n:scan": "i18next-cli extract"
  },
  "exports": {
    ".": "./src/index.ts",
    "./templates/*": "./src/templates/*.tsx",
    "./locales/*": "./locales/en/*.json"
  },
  "dependencies": {
    "@aws-sdk/client-ses": "^3.501.0",
    "@aws-sdk/credential-provider-node": "^3.501.0",
    "@rallly/logger": "workspace:*",
    "@rallly/utils": "workspace:*",
    "@react-email/components": "^1.0.12",
    "@react-email/render": "^2.0.9",
    "i18next": "^26.3.0",
    "i18next-icu": "^2.4.3",
    "i18next-resources-to-backend": "^1.2.1",
    "nodemailer": "^6.9.9",
    "react": "19.2.6",
    "react-dom": "19.2.6",
    "react-i18next": "^17.0.8"
  },
  "devDependencies": {
    "@rallly/tailwind-config": "workspace:*",
    "@rallly/tsconfig": "workspace:*",
    "@react-email/ui": "^6.6.3",
    "@types/nodemailer": "^6.4.14",
    "i18next-cli": "^1.58.1",
    "react-email": "^6.6.3"
  }

    "i18next": "^26.3.0",
    "i18next-icu": "^2.4.3",
    "i18next-resources-to-backend": "^1.2.1",
    "nodemailer": "^6.9.9",
    "react": "19.2.6",
    "react-dom": "19.2.6",
    "react-i18next": "^17.0.8"
  },
  "devDependencies": {
    "@rallly/tailwind-config": "workspace:*",
    "@rallly/tsconfig": "workspace:*",
    "@react-email/preview-server": "5.2.7",

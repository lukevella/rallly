{
  "name": "@rallly/api",
  "version": "0.0.0",
  "private": true,
  "main": "dist/index.js",
  "scripts": {
    "dev": "portless api.local.rallly tsx watch --clear-screen=false --include 'src/**/*.ts' --env-file-if-exists=.env src/index.ts",
    "build": "tsc",
    "start": "node --env-file-if-exists=.env dist/index.js",
    "test:unit": "vitest run",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "@hono-rate-limiter/redis": "^0.1.4",
    "@hono/node-server": "^1.19.9",
    "@hono/zod-openapi": "^1.2.0",
    "@rallly/api-core": "workspace:*",
    "@rallly/database": "workspace:*",
    "@rallly/logger": "workspace:*",
    "@rallly/utils": "workspace:*",
    "@scalar/hono-api-reference": "^0.9.30",
    "@t3-oss/env-core": "^0.13.10",
    "@upstash/redis": "^1.36.2",
    "dayjs": "^1.11.13",
    "hono": "^4.11.1",
    "hono-openapi": "^1.1.2",
    "hono-rate-limiter": "^0.2.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@rallly/tsconfig": "workspace:*",
    "@types/node": "^24.1.0",
    "tsx": "^4.6.2",
    "typescript": "^5.8.2",
    "vitest": "^4.0.16"
  }
}

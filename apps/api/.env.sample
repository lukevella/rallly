# A connection string to your Postgres database (required)
DATABASE_URL=postgres://postgres:postgres@localhost:5450/rallly

# The base URL of the web app, used to build adminUrl/inviteUrl in API responses (required)
WEB_BASE_URL=https://web.local.rallly.co

# Optional short URL base for invite links. Defaults to WEB_BASE_URL.
WEB_SHORT_URL=

# Port the API server listens on (defaults to 4000)
PORT=4000

# Upstash Redis for distributed rate limiting (optional)
# When unset, hono-rate-limiter falls back to in-memory.
KV_REST_API_URL=
KV_REST_API_TOKEN=
